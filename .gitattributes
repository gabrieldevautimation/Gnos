# ─── Git Attributes ───────────────────────────────────────────────────────────
# Normaliza line endings para LF em todo o projeto
# Evita problemas cross-platform (Windows dev → Linux CI/containers)

* text=auto eol=lf

# Arquivos que devem ser sempre LF
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.json  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.md    text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.prisma text eol=lf
*.env*  text eol=lf

# Binários — não normalizar
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.svg   binary
*.ico   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
