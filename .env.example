# ─── Gnos — Environment Variables ─────────────────────────────────────────────
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o .env — ele está no .gitignore

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:3000

# ─── Supabase ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/gnos?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/gnos?schema=public"
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── N8N ──────────────────────────────────────────────────────────────────────
N8N_WEBHOOK_URL=http://localhost:5678/webhook/gnos-events
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=gnos-secret

# ─── Redis (Fase 2) ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxx
FROM_EMAIL=noreply@gnos.digital

# ─── CMS (Sanity) ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=xxxx
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=sk_xxxx
