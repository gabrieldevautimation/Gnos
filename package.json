{
  "name": "gnos",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=web",
    "dev:portal": "turbo run dev --filter=portal",
    "dev:api": "turbo run dev --filter=api",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "clean": "turbo run clean && rimraf node_modules",
    "db:generate": "pnpm --filter @gnos/database db:generate",
    "db:migrate": "pnpm --filter @gnos/database db:migrate",
    "db:migrate:prod": "pnpm --filter @gnos/database db:migrate:prod",
    "db:seed": "pnpm --filter @gnos/database db:seed",
    "db:studio": "pnpm --filter @gnos/database db:studio",
    "db:reset": "pnpm --filter @gnos/database db:reset",
    "setup:db": "node scripts/setup-db.mjs",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "rimraf": "^6.0.1",
    "turbo": "^2.9.6",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
